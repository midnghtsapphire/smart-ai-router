# OpenRouter API Key
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# Default Model Settings
OPENROUTER_DEFAULT_MODEL=openrouter/free
OPENROUTER_MAX_TOKENS=4096

# Provider Preferences (global defaults)
OPENROUTER_PROVIDER_SORT=price
OPENROUTER_PROVIDER_ALLOW_FALLBACKS=true
OPENROUTER_PROVIDER_DATA_COLLECTION=deny

# Rate Limit Boost (purchase $10 to unlock)
OPENROUTER_CREDITS_PURCHASED=true  # Set after buying $10

# Cost Control
OPENROUTER_DAILY_BUDGET=10.00
OPENROUTER_ALERT_EMAIL=your-email@example.com

# App Attribution
HTTP_REFERER=https://yourapp.com
X_TITLE=YourApp-OpenClaw-Agent
